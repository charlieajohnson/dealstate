# Public site origin for canonical links, sitemap and Open Graph image URLs.
# Optional on Vercel: the build derives it from VERCEL_PROJECT_PRODUCTION_URL.
# Set explicitly for a custom domain or a local production build.
NEXT_PUBLIC_SITE_URL=

# Seed mode works without credentials.
USE_SUPABASE=false
# TODO(init): Set these only when switching to the optional Supabase repository.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase key for migrations, ingestion jobs and storage writes.
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Provider-agnostic model configuration. CI evals run offline unless --live is passed.
MODEL_PROVIDER=
MODEL_ID=
EMBEDDING_MODEL_ID=
OPENAI_API_KEY=

# Encryption key for third-party OAuth token storage.
TOKEN_ENCRYPTION_KEY=

# Gmail connector OAuth configuration.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
GMAIL_TEST_USER=
