{
  "name": "dealstate",
  "version": "0.1.0",
  "private": true,
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "validate-data": "tsx scripts/validate-data.ts",
    "lint:copy": "tsx scripts/lint-copy.ts",
    "validate": "npm run validate-data && npm run lint:copy && npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.108.2",
    "@tailwindcss/postcss": "4.3.1",
    "geist": "1.7.2",
    "next": "15.5.19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "9.1.0",
    "recharts": "2.15.4",
    "remark-gfm": "4.0.1",
    "tailwindcss": "4.3.1",
    "yaml": "2.9.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.19",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
